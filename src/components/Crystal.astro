---

<div class="crystal-container">
	<canvas id="crystal-canvas"></canvas>
</div>

<style>
	.crystal-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointers: none;
		z-index: 1;
		overflow: hidden;
	}

	#crystal-canvas {
		width: 100%;
		height: 100%;
	}
</style>

<script>
	import * as THREE from 'three';

	const canvas = document.getElementById('crystal-canvas') as HTMLCanvasElement;

	const rootStyles = getComputedStyle(document.documentElement);
	const brandBlue = rootStyles.getPropertyValue('--brand-primary').trim();
	const brandBlueLight = rootStyles
		.getPropertyValue('--brand-primary-light')
		.trim();

	function hexToThreeColor(hex: string): number {
		return parseInt(hex.replace('#', ''), 16);
	}

	const scene = new THREE.Scene();
	const camera = new THREE.PerspectiveCamera(
		75,
		window.innerWidth / window.innerHeight,
		0.1,
		1000,
	);
	camera.position.z = 5;

	const renderer = new THREE.WebGLRenderer({
		canvas,
		alpha: true,
		antialias: true,
	});
	renderer.setSize(window.innerWidth, window.innerHeight);
	renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

	const geometry = new THREE.IcosahedronGeometry(1.5, 0);

	const material = new THREE.MeshPhysicalMaterial({
		color: hexToThreeColor(brandBlue),
		metalness: 0.1,
		roughness: 0.1,
		transmission: 0.9,
		thickness: 0.5,
		transparent: true,
		opacity: 0.8,
		clearcoat: 1,
		clearcoatRoughness: 0.1,
		envMapIntensity: 1,
		ior: 2.4,
		side: THREE.DoubleSide,
	});

	const crystal = new THREE.Mesh(geometry, material);
	crystal.position.set(3, 0, 0);
	scene.add(crystal);

	const innerGeometry = new THREE.IcosahedronGeometry(0.8, 1);
	const innerMaterial = new THREE.MeshPhysicalMaterial({
		color: hexToThreeColor(brandBlueLight),
		metalness: 0.2,
		roughness: 0.05,
		transmission: 0.95,
		thickness: 0.3,
		transparent: true,
		opacity: 0.6,
		clearcoat: 1,
	});
	const innerCrystal = new THREE.Mesh(innerGeometry, innerMaterial);
	innerCrystal.position.set(3, 0, 0);
	scene.add(innerCrystal);

	const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
	scene.add(ambientLight);

	const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
	directionalLight.position.set(5, 5, 5);
	scene.add(directionalLight);

	const pointLight1 = new THREE.PointLight(hexToThreeColor(brandBlue), 2, 10);
	pointLight1.position.set(-3, 2, 3);
	scene.add(pointLight1);

	const pointLight2 = new THREE.PointLight(
		hexToThreeColor(brandBlueLight),
		2,
		10,
	);
	pointLight2.position.set(3, -2, 3);
	scene.add(pointLight2);

	let mouseX = 0;
	let mouseY = 0;
	let targetX = 0;
	let targetY = 0;

	document.addEventListener('mousemove', (e) => {
		mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
		mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
	});

	function animate() {
		requestAnimationFrame(animate);

		targetX = mouseX * 0.3;
		targetY = mouseY * 0.3;

		crystal.rotation.x += 0.005;
		crystal.rotation.y += 0.008;
		crystal.position.x += (3 + targetX - crystal.position.x) * 0.05;
		crystal.position.y += (targetY - crystal.position.y) * 0.05;

		innerCrystal.rotation.x -= 0.003;
		innerCrystal.rotation.y -= 0.005;
		innerCrystal.position.x = crystal.position.x;
		innerCrystal.position.y = crystal.position.y;

		renderer.render(scene, camera);
	}

	animate();

	window.addEventListener('resize', () => {
		camera.aspect = window.innerWidth / window.innerHeight;
		camera.updateProjectionMatrix();
		renderer.setSize(window.innerWidth, window.innerHeight);
	});
</script>
