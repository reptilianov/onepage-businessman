		.contact {
			display: none;
		}

		.contact-box {
			position: fixed;
			bottom: -5px;
			left: 2rem;
			width: 400px;
			max-width: calc(100vw - 4rem);
			z-index: 100;
			backdrop-filter: blur(20px);
			-webkit-backdrop-filter: blur(20px);
			background: rgba(152, 178, 250, 0.158);
			border: 2px solid var(--brand-primary-light);
			padding: 2rem;
			box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
			mix-blend-mode: luminosity;
			background-color: #665ad7;
			opacity: 0;
			visibility: visible;
			animation: slideUp 0.5s ease-out 10s forwards;

			h2 {
				font-size: 1.5rem;
				margin-bottom: 0.75rem;
				color: var(--brand-primary-light);
			}

