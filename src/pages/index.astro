				padding: 0.75rem 1rem;
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid rgba(255, 255, 255, 0.15);

				color: var(--light);
				font-size: 0.95rem;

				&:focus {
					outline: none;
					border-color: var(--brand-primary-light);
				}

