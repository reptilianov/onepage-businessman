		// =====================================================================
		// DIAMOND SCROLL MOVEMENT
		// =====================================================================
		// This code makes diamonds move with scroll for a parallax effect
		// Each diamond has individual scroll speed via data-scroll-speed attribute
		// Adjust values in HTML (0.05 = very slow, 0.5 = fast)
		// =====================================================================
		document.addEventListener('DOMContentLoaded', function () {
			const diamondContainers = document.querySelectorAll('.diamond-container');

			// Store original positions and scroll speeds
			const diamondData = [];
			diamondContainers.forEach((container, index) => {
				// Get scroll speed from data attribute or use default
				const scrollSpeed =
					parseFloat(container.getAttribute('data-scroll-speed')) || 0.2;

				// Parse original style values
				const style = container.style;
				const originalTop = style.top ? parseFloat(style.top) : null;
				const originalBottom = style.bottom ? parseFloat(style.bottom) : null;
				const originalLeft = style.left ? parseFloat(style.left) : null;
				const originalRight = style.right ? parseFloat(style.right) : null;

				// Determine positioning type
				const hasTop = style.top && style.top.includes('px');
				const hasBottom = style.bottom && style.bottom.includes('px');
				const hasLeft = style.left && style.left.includes('px');
				const hasRight = style.right && style.right.includes('px');

				// For calc() values (like calc(50vh - 160px)), we need to compute them
				let computedTop = originalTop;
				let computedBottom = originalBottom;
				let computedLeft = originalLeft;
				let computedRight = originalRight;

				// If values are calc(), compute them once
				if (style.top && style.top.includes('calc')) {
					container.style.top = style.top; // Ensure it's set
					const rect = container.getBoundingClientRect();
					computedTop = rect.top;
				}
				if (style.bottom && style.bottom.includes('calc')) {
					container.style.bottom = style.bottom;
					const rect = container.getBoundingClientRect();
					computedBottom = window.innerHeight - rect.bottom;
				}

				diamondData[index] = {
					scrollSpeed,
					originalTop: computedTop,
					originalBottom: computedBottom,
					originalLeft: computedLeft,
					originalRight: computedRight,
					hasTop,
					hasBottom,
					hasLeft,
					hasRight,
					// Store original calc strings for recalculation on resize
					originalTopString: style.top,
					originalBottomString: style.bottom,
					originalLeftString: style.left,
					originalRightString: style.right,
				};
			});

			function updateDiamondPositions() {
				const scrollY = window.scrollY;

				diamondContainers.forEach((container, index) => {
					const data = diamondData[index];
					const movement = scrollY * data.scrollSpeed;

					// Apply vertical movement based on original positioning
					if (data.hasTop && data.originalTop !== null) {
						container.style.top = `${data.originalTop + movement}px`;
					}
					if (data.hasBottom && data.originalBottom !== null) {
						container.style.bottom = `${data.originalBottom - movement}px`;
					}

					// Optional: Add slight horizontal movement for more dynamic effect
					// Horizontal movement is 30% of vertical movement
					const horizontalMovement = movement * 0.3;
					if (data.hasLeft && data.originalLeft !== null) {
						container.style.left = `${data.originalLeft + horizontalMovement}px`;
					}
					if (data.hasRight && data.originalRight !== null) {
						container.style.right = `${data.originalRight - horizontalMovement}px`;
					}
				});
			}

			// Throttle scroll events for performance
			let scrollTimeout;
			window.addEventListener('scroll', function () {
				if (!scrollTimeout) {
					scrollTimeout = setTimeout(function () {
						scrollTimeout = null;
						updateDiamondPositions();
					}, 16); // ~60fps
				}
			});

			// Recalculate on window resize (for calc() values)
			window.addEventListener('resize', function () {
				diamondContainers.forEach((container, index) => {
					const data = diamondData[index];
					// Re-apply original calc strings and recompute
					if (
						data.originalTopString &&
						data.originalTopString.includes('calc')
					) {
						container.style.top = data.originalTopString;
						const rect = container.getBoundingClientRect();
						data.originalTop = rect.top;
					}
					if (
						data.originalBottomString &&
						data.originalBottomString.includes('calc')
					) {
						container.style.bottom = data.originalBottomString;
						const rect = container.getBoundingClientRect();
						data.originalBottom = window.innerHeight - rect.bottom;
					}
				});
				updateDiamondPositions();
			});

			// Initial position update
			updateDiamondPositions();
		});
		// =====================================================================
		// COLLAGE REVEAL ANIMATION
		// =====================================================================
		// This code adds 'revealed' class to collage images when they enter viewport
		// Uses IntersectionObserver with staggered delays from data-reveal-delay attribute
		// =====================================================================
		document.addEventListener('DOMContentLoaded', function () {
			const collageItems = document.querySelectorAll('.collage-img');
			if (collageItems.length === 0) return;

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const img = entry.target;
							const delay =
								parseInt(
									img
										.closest('.collage-item')
										.getAttribute('data-reveal-delay'),
								) || 0;

							setTimeout(() => {
								img.classList.add('revealed');
							}, delay);

							observer.unobserve(img);
						}
					});
				},
				{
					threshold: 0.2,
					rootMargin: '0px 0px -50px 0px',
				},
			);

			collageItems.forEach((img) => observer.observe(img));
		});
		// =====================================================================
		// COLLAGE SCROLL MOVEMENT
		// =====================================================================
		// This code makes collage images move with scroll for a parallax effect
		// Each image has individual scroll speed via data-scroll-speed attribute
		// =====================================================================
		document.addEventListener('DOMContentLoaded', function () {
			const collageItems = document.querySelectorAll('.collage-item');
			if (collageItems.length === 0) return;

			const itemData = [];
			collageItems.forEach((item, index) => {
				const scrollSpeed =
					parseFloat(item.getAttribute('data-scroll-speed')) || 0.2;
				const rect = item.getBoundingClientRect();
				const top = rect.top + window.scrollY;
				itemData[index] = { scrollSpeed, originalTop: top, item };
			});

			function updateCollagePositions() {
				if (window.innerWidth < 900) return;
				const scrollY = window.scrollY;
				itemData.forEach((data) => {
					const movement =
						(scrollY - data.originalTop) * data.scrollSpeed * 0.1;
					data.item.style.transform = 'translateY(' + movement + 'px)';
				});
			}

			let scrollTimeout;
			window.addEventListener('scroll', function () {
				if (!scrollTimeout) {
					scrollTimeout = setTimeout(function () {
						scrollTimeout = null;
						updateCollagePositions();
					}, 16);
				}
			});

			window.addEventListener('resize', function () {
				collageItems.forEach((item, index) => {
					const rect = item.getBoundingClientRect();
					itemData[index].originalTop = rect.top + window.scrollY;
				});
				updateCollagePositions();
			});

			updateCollagePositions();
		});
		// =====================================================================
	</script>
</Layout>
