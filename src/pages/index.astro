---
import Layout from '../layouts/Layout.astro';

let posts = [];
try {
	const res = await fetch(
		'http://soybogart.com/blog/wp-json/wp/v2/posts?_embed',
	);
	if (res.ok) {
		posts = await res.json();
	}
} catch (e) {
	console.warn('Could not fetch blog posts:', e);
}
---

<Layout
	title="Alberto Bogart - terapeuta de negocios 2026 - Be ready for tomorrow">
	<nav class="navbar">
		<div class="nav-content">
			<a
				href="#"
				class="logo">
				<img
					src="assets/svg/LogoBogartWhite.svg"
					alt="Alberto Bogart - terapeuta de negocios"
				/>
			</a>
			<div class="nav-links">
				<a href="#about">Trayectoria</a>
				<a href="#blog">Blog</a>
				<a href="#contact">Conozcamonos</a>
			</div>
		</div>
	</nav>

	<section
		id="hero"
		class="hero">
		<div class="hero-bg">
			<div class="grid-overlay"></div>
			<div class="glow-orb orb-1"></div>
			<div class="glow-orb orb-2"></div>
		</div>
		<div
			class="hero-gem w-embed"
			aria-hidden="true">
			<video
				width="100%"
				height="100%"
				autoplay
				loop
				muted
				playsinline>
				<source
					src="https://soybogart.com/assets/Roca.mp4"
					type='video/mp4; codecs="hvc1"'
				/>
				<source
					src="https://soybogart.com/assets/Roca.webm"
					type="video/webm"
				/>
				<img
					src="https://soybogart.com/assets/Roca.webp"
					alt="Clear Crystal"
				/>
			</video>
		</div>
		<div class="hero-content container">
			<h1
				class="display-1"
				data-aos="fade-up"
				data-aos-delay="100">
				<span class="gradient-text light-weight">PREPÁRATE PARA</span>
				<span
					class="rotating-text"
					data-words="EMPRENDER,CRECER,INNOVAR,TRANSFORMAR,AVANZAR"
					>EMPRENDER</span
				>
			</h1>

			<p
				class="hero-description"
				data-aos="fade-up"
				data-aos-delay="300">
				El estratega creativo y Terapeuta de Marcas que ayuda a los
				emprendedores a dejar de improvisar. Brindo capacitaciones dinámicas,
				consultoría 1:1 y diseño de estrategias de marketing donde el humanismo,
				la creatividad y la innovación son el alma de cada resultado.
			</p>
		</div>
	</section>

	<section
		id="about"
		class="about">
		<div class="container">
			<div class="about-grid">
				<div
					class="about-image"
					data-aos="fade-right">
					<img
						src="/assets/img/albertoBogart-b.webp"
						alt="Bogart"
					/>
				</div>
				<div
					class="about-content"
					data-aos="fade-left">
					<span class="section-tag text-brand-primary">SOY BOGART</span>
					<h2 class="text-brand-primary">
						El estratega creativo y Terapeuta de Marcas que ayuda a los
						emprendedores a dejar de improvisar.
					</h2>
					<p class="about-description">
						Brindo capacitaciones dinámicas, consultoría 1:1 y diseño de
						estrategias de marketing donde el humanismo, la creatividad y la
						innovación son el alma de cada resultado.
					</p>
					<a
						href="#servicios"
						class="btn btn-primary"
						>Ver Servicios</a
					>
				</div>
			</div>
		</div>
	</section>

	<section
		id="trayectoria"
		class="trayectoria">
		<div class="container">
			<div
				class="section-header"
				data-aos="fade-up">
				<span class="section-tag">Mi Trayectoria</span>
				<h2>Números que <span class="gradient-text">Hablan</span></h2>
			</div>
			<div class="stats-grid">
				<div
					class="stat-card"
					data-aos="zoom-in"
					data-aos-delay="100">
					<span
						class="stat-number"
						data-target="15"
						>0</span
					>
					<span class="stat-label">Proyectos</span>
				</div>
				<div
					class="stat-card"
					data-aos="zoom-in"
					data-aos-delay="200">
					<span
						class="stat-number"
						data-target="200"
						>0</span
					>
					<span class="stat-label">Capacitaciones</span>
				</div>
				<div
					class="stat-card"
					data-aos="zoom-in"
					data-aos-delay="300">
					<span
						class="stat-number"
						data-target="20"
						>0</span
					>
					<span class="stat-label">Años de experiencia</span>
				</div>
				<div
					class="stat-card"
					data-aos="zoom-in"
					data-aos-delay="400">
					<span
						class="stat-number"
						data-target="50"
						>0</span
					>
					<span class="stat-label">Marcas creadas</span>
				</div>
			</div>
		</div>
	</section>

	<section
		id="servicios"
		class="servicios">
		<div class="container">
			<div
				class="section-header"
				data-aos="fade-up">
				<span class="section-tag">Mis Servicios</span>
				<h2>Estrategia con <span class="gradient-text">Alma</span></h2>
			</div>
			<div class="servicios-grid">
				<div
					class="servicio-card"
					data-num="01"
					data-aos="fade-right"
					data-aos-delay="100">
					<h3>Capacitación Dinámica</h3>
					<p>
						Formación disruptiva para equipos y mentes inquietas que buscan
						accionar el conocimiento.
					</p>
					<ul>
						<li>Emprendimiento</li>
						<li>Ventas</li>
						<li>Planeación estratégica</li>
						<li>Negocios digitales</li>
					</ul>
				</div>
				<div
					class="servicio-card"
					data-num="02"
					data-aos="fade-left"
					data-aos-delay="150">
					<h3>Consultoría Estratégica 1:1</h3>
					<p>
						Acompañamiento profundo para líderes y emprendedores que decidieron
						dejar de improvisar.
					</p>
					<ul>
						<li>Sesiones presenciales (GDL, CDMX, Bogotá)</li>
						<li>Sesiones de 1.5 horas</li>
						<li>Terapeuta de marca</li>
						<li>Acompañamiento mensual</li>
					</ul>
				</div>
				<div
					class="servicio-card"
					data-num="03"
					data-aos="fade-right"
					data-aos-delay="200">
					<h3>Branding & Identidad</h3>
					<p>Creación de marcas con esencia para conectar emocionalmente.</p>
					<ul>
						<li>Logotipo + identidad corporativa</li>
						<li>Diseño publicitario</li>
						<li>Creación de marcas comerciales</li>
						<li>Registro y protección de marcas</li>
					</ul>
				</div>
				<div
					class="servicio-card"
					data-num="04"
					data-aos="fade-left"
					data-aos-delay="250">
					<h3>Marketing Digital & Contenido</h3>
					<p>
						Storytelling estratégico y presencia digital para convertir tu marca
						en comunidad.
					</p>
					<ul>
						<li>Foto-video comercial</li>
						<li>Campañas Facebook e Instagram</li>
						<li>Campañas Google + YouTube</li>
						<li>Creación de contenido</li>
					</ul>
				</div>
				<div
					class="servicio-card"
					data-num="05"
					data-aos="fade-right"
					data-aos-delay="300">
					<h3>Web & E-commerce</h3>
					<p>
						Tu plaza digital de alto rendimiento, diseñada para vender 24/7.
					</p>
					<ul>
						<li>Sitios web y tiendas en línea</li>
						<li>Optimizados SEO/SEM</li>
						<li>Sistemas y Apps</li>
						<li>Código real (sin IA)</li>
					</ul>
				</div>
				<div
					class="servicio-card"
					data-num="06"
					data-aos="fade-left"
					data-aos-delay="350">
					<p>
						Porque siempre hay buen puerto para quien sabe a dónde se dirige.
					</p>
					<ul>
						<li>Digitalización de negocios</li>
						<li>Diagnóstico y auditoría</li>
						<li>Manuales internos</li>
						<li>Herramientas de gestión</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="misEmprendimientos">
		<div class="container">
			<h1 class="text-brand-primary">Mis emprendimientos</h1>
			<div class="emprendimiento-card">
				<img
					src="/assets/svg/logo-1.svg"
					alt=""
				/>
			</div>
			<div class="emprendimiento-card">
				<img
					src="/assets/svg/logo-2.svg"
					alt=""
				/>
			</div>
			<div class="emprendimiento-card">
				<img
					src="/assets/svg/logo-3.svg"
					alt=""
				/>
			</div>
			<div class="emprendimiento-card">
				<img
					src="/assets/svg/logo-4.svg"
					alt=""
				/>
			</div>
			<div class="emprendimiento-card">
				<img
					src="/assets/svg/logo-5.svg"
					alt=""
				/>
			</div>
		</div>
	</section>

	<section
		id="newsletter"
		class="newsletter">
		<div
			class="newsletter-popup"
			id="newsletter-popup">
			<button
				class="newsletter-close"
				id="newsletter-close"
				>&times;</button
			>
			<h2>SUSCRÍBETE A MI NEWSLETTER</h2>
			<p>
				Únete a miles de personas que semanalmente reciben contenido exclusivo
			</p>
			<form
				class="newsletter-form"
				id="newsletter-form">
				<input
					type="text"
					name="nombre"
					placeholder="Tu nombre"
					required
				/>
				<input
					type="email"
					name="email"
					placeholder="Tu email"
					required
				/>
				<button
					type="submit"
					id="newsletter-submit"
					class="btn btn-primary"
					>REGÍSTRATE HOY</button
				>
			</form>
		</div>
	</section>

	<section
		id="collage"
		class="collage">
		<div class="collage-grid">
			<!-- Image 1 -->
			<div
				class="collage-item"
				style="margin: 0 -42px 20px 14px;"
				data-scroll-speed="0.15"
				data-reveal-delay="0">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-1.jpg"
					alt="Alberto Bogart"
				/>
			</div>
			<!-- Image 2 -->
			<div
				class="collage-item"
				style="margin: -50px -42px 0 -14px;"
				data-scroll-speed="0.25"
				data-reveal-delay="100">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-2.jpg"
					alt="Alberto Bogart"
				/>
			</div>
			<!-- Image 3 -->
			<div
				class="collage-item"
				style="margin: 50px -42px 0 -14px;"
				data-scroll-speed="0.1"
				data-reveal-delay="200">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-3.jpg"
					alt="Alberto Bogart"
				/>
			</div>
			<!-- Image 4 -->
			<div
				class="collage-item"
				style="margin: 70px -100px 0 -14px;"
				data-scroll-speed="0.3"
				data-reveal-delay="300">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-4.jpg"
					alt="Alberto Bogart"
				/>
			</div>
			<!-- Image 5 -->
			<div
				class="collage-item"
				style="margin: 100px 80px 0 -14px;"
				data-scroll-speed="0.2"
				data-reveal-delay="400">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-5.jpg"
					alt="Alberto Bogart"
				/>
			</div>
			<!-- Image 6 & 7 container -->
			<div
				class="collage-item"
				style="margin: 0 -42px 0 -14px;"
				data-scroll-speed="0.05"
				data-reveal-delay="500">
				<img
					class="collage-img"
					src="/assets/img/albertoBogart-6.jpg"
					alt="Alberto Bogart"
				/>
				<div
					class="collage-item"
					style="margin: 0 -42px 0 -14px;"
					data-scroll-speed="0.35"
					data-reveal-delay="600">
					<img
						class="collage-img"
						src="/assets/img/albertoBogart-7.jpg"
						alt="Alberto Bogart"
					/>
				</div>
			</div>
		</div>
	</section>

	<div id="contact" class="contact-box">
		<h2>¿Listo para el <span class="gradient-text">Futuro</span>?</h2>
		<form
			class="contact-form"
			id="contact-form">
			<input
				type="text"
				name="nombre"
				placeholder="Tu nombre"
				required
			/>
			<input
				type="email"
				name="email"
				placeholder="Tu email"
				required
			/>
			<button
				type="submit"
				id="contact-submit"
				class="btn btn-primary"
				>Registrarme</button
			>
		</form>
	</div>

	<section
		id="blog"
		class="blog-section">
		<div class="container">
			<h2 data-aos="fade-up">Terapeuta de Negocios</h2>
			{
				posts.length > 0 ? (
					<>
						<article
							class="featured-post"
							data-aos="fade-up"
							data-aos-delay="100">
							<a href={`/blog/${posts[0].slug}`}>
								<div class="featured-image">
									<img
										src={
											posts[0]._embedded?.['wp:featuredmedia']?.[0]
												?.source_url || '/assets/img/placeholder.jpg'
										}
										alt={posts[0].title.rendered}
									/>
								</div>
								<div class="featured-content">
									<span class="featured-badge">Más reciente</span>
									<h3 set:html={posts[0].title.rendered} />
									<div
										class="blog-excerpt"
										set:html={posts[0].excerpt.rendered}
									/>
									<span class="blog-read-more">Leer artículo completo →</span>
								</div>
							</a>
						</article>

						{posts.length > 1 && (
							<div class="blog-grid">
								{posts.slice(1).map((post, index) => (
									<article
										class="blog-card"
										data-aos="fade-up"
										data-aos-delay={150 + index * 50}>
										<a href={`/blog/${post.slug}`}>
											<div class="blog-image">
												<img
													src={
														post._embedded?.['wp:featuredmedia']?.[0]
															?.source_url || '/assets/img/placeholder.jpg'
													}
													alt={post.title.rendered}
												/>
											</div>
											<h3 set:html={post.title.rendered} />
											<div
												class="blog-excerpt"
												set:html={post.excerpt.rendered}
											/>
											<span class="blog-read-more">Leer más →</span>
										</a>
									</article>
								))}
							</div>
						)}
					</>
				) : (
					<p class="blog-loading">Cargando entradas del blog...</p>
				)
			}
		</div>
	</section>

	<footer class="footer">
		<div class="container">
			<div class="footer-content">
				<div class="footer-brand">
					<img
						src="assets/svg/LogoBogartWhite.svg"
						alt="Alberto Bogart - terapeuta de negocios"
					/>
					<p>Alberto Bogart - terapeuta de negocios 2026</p>
				</div>

				<div class="footer-social">
					<a
						href="https://www.youtube.com/@bogartalberto7109"
						aria-label="Youtube">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><path
								d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"
							></path></svg
						>
					</a>
					<a
						href="https://www.instagram.com/bogart_alberto/"
						aria-label="Instagram">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							><rect
								x="2"
								y="2"
								width="20"
								height="20"
								rx="5"
								ry="5"
							></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
							></path><line
								x1="17.5"
								y1="6.5"
								x2="17.51"
								y2="6.5"
							></line></svg
						>
					</a>
				</div>
			</div>
			<div class="footer-bottom">
				<p>
					© 2026 Alberto Bogart - terapeuta de negocios . Todos los derechos
					reservados.
				</p>
			</div>
		</div>
	</footer>

	<style>
		.gradient-text {
			background: linear-gradient(
				135deg,
				var(--light),
				var(--brand-primary-light)
			);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}

		.navbar {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 100;
			padding: 1rem 2rem;
			backdrop-filter: blur(10px);
			background: #0600ff24;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);

			.nav-content {
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.logo img {
				filter: brightness(0) invert(1);
			}

			.logotipo {
				mix-blend-mode: invert;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 2rem;

				a {
					color: var(--lighter);
					text-decoration: none;
					transition: color 0.3s ease;

					&:hover {
						color: var(--light);
					}
				}

				.btn-nav {
					background: var(--brand-primary);
					color: white !important;
					padding: 0.5rem 1rem;

					&:hover {
						background: var(--brand-primary-light);
					}
				}
			}
		}

		.hero {
			min-height: 100vh;
			position: relative;
			overflow: hidden;

			.hero-bg {
				position: absolute;
				inset: 0;
				z-index: 0;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				text-align: center;
				padding-top: 6rem;
			}

			.grid-overlay {
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(37, 99, 235, 0.1) 1px, transparent 1px),
					linear-gradient(90deg, rgba(37, 99, 235, 0.1) 1px, transparent 1px);
				background-size: 50px 50px;
			}

			.glow-orb {
				position: absolute;

				filter: blur(100px);
				opacity: 0.5;
			}

			.orb-1 {
				width: 600px;
				height: 600px;
				background: var(--brand-primary);
				top: -200px;
				right: -200px;
			}

			.orb-2 {
				width: 400px;
				height: 400px;
				background: var(--brand-primary-light);
				bottom: -100px;
				left: -100px;
			}

			.hero-content {
				position: relative;
				z-index: 1;
				text-align: center;
				padding-top: 6rem;
			}

			.badge {
				display: inline-block;
				padding: 0.5rem 1rem;
				background: rgba(37, 99, 235, 0.2);
				border: 1px solid var(--brand-primary);

				font-size: 0.875rem;
				color: var(--brand-primary-light);
				margin-bottom: 2rem;
			}
			h1 {
				font-size: clamp(5em, 13vw, 9rem);
				line-height: 1;
				margin-bottom: 1rem;

				.light-weight {
					font-weight: 300;
					font-family: 'Exo', sans-serif;
				}

				.rotating-text {
					font-weight: 800;
					font-family: 'Exo', sans-serif;
				}
			}

			.hero-tagline {
				font-size: clamp(1.5rem, 4vw, 2.5rem);
				color: var(--lighter);
				margin-bottom: 1rem;
			}

			.hero-description {
				font-size: 1.3rem;
				color: var(--lighter);
				max-width: 800px;
				margin: 0 auto 2rem;
			}

			.hero-actions {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-bottom: 4rem;
			}

			.btn-primary {
				background: var(--brand-primary);
			}

			.btn-secondary {
				background: transparent;
				border: 1px solid var(--lighter);

				&:hover {
					border-color: var(--brand-primary);
					background: rgba(37, 99, 235, 0.1);
				}
			}

			.hero-stats {
				display: flex;
				justify-content: center;
				gap: 4rem;

				.stat {
					text-align: center;
				}

				.stat-number {
					display: block;
					font-size: 2.5rem;
					font-weight: 700;
					color: var(--brand-primary);
				}

				.stat-label {
					color: var(--lighter);
					font-size: 0.875rem;
				}
			}
		}

		.scroll-indicator {
			position: absolute;
			bottom: 2rem;
			left: 50%;
			transform: translateX(-50%);
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
			color: var(--lighter);
			font-size: 0.75rem;

			.mouse {
				width: 24px;
				height: 40px;
				border: 2px solid var(--lighter);

				position: relative;

				.wheel {
					width: 4px;
					height: 8px;
					background: var(--brand-primary);

					position: absolute;
					top: 8px;
					left: 50%;
					transform: translateX(-50%);
					animation: scroll 1.5s infinite;
				}
			}
		}

		@keyframes scroll {
			0% {
				opacity: 1;
				transform: translateX(-50%) translateY(0);
			}
			100% {
				opacity: 0;
				transform: translateX(-50%) translateY(12px);
			}
		}

		.section-header {
